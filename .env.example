# Supabase cross-device sync (optional).
# Copy this file to .env.local and fill in your project's values.
# Without these, the app runs exactly as before — the cloud-sync UI stays hidden.
#
# Found in the Supabase dashboard under Project Settings → API.
# The anon key is public-by-design; access is gated by the *_vault RPC PIN check.
#
# NOTE: Vite inlines VITE_* at build time. For the live site, also set these in the
# Vercel project's Environment Variables and redeploy.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
